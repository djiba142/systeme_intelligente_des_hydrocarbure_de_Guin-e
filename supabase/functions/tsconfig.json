{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "moduleResolution": "bundler"
  },
  "include": [
    "./**/*.ts",
    "./_types/**/*.d.ts"
  ],
  "exclude": [
    "../../node_modules"
  ]
}
